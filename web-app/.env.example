# ============================================================
# Variables de entorno - Copia este archivo como .env.local
# y rellena con los valores de tu Vercel Postgres (Neon)
# ============================================================

# Estas variables las obtienes de: Vercel Dashboard → Storage → tu DB → .env.local tab
POSTGRES_URL=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NO_SSL=""
POSTGRES_URL_NON_POOLING=""
POSTGRES_USER=""
POSTGRES_HOST=""
POSTGRES_PASSWORD=""
POSTGRES_DATABASE=""

# API Key de seguridad para el ESP32 (puedes poner cualquier string secreto)
ESP32_API_KEY="mi-clave-secreta-123"
